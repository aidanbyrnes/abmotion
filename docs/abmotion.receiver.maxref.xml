<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<?xml-stylesheet href="./c74ref.xsl" type="text/xsl"?>

<c74object name="abmotion.receiver">

<digest>
    Connect to abmotion receiver
</digest>
​
<description>
    Connect to abmotion receiver. Routes data to abmotion objects.
</description>

<!--METADATA-->
<metadatalist>
    <metadata name="author">Aidan Byrnes</metadata>
</metadatalist>

<inletlist>
    <inlet id="0" type="int">
        <digest>Device serial port.</digest>
    </inlet>
</inletlist>

<objarglist>
    <objarg name="serialport" optional="1" type="int">
        <digest>Device serial port.</digest>
    </objarg>
</objarglist>

</c74object>
